// test: method returns templated generic Collection<T> via constructor inference
// feature: completion
// Adapted from phpactor generics/method_returns_templated_generic.test
// expect: doWork(
---
<?php

class MyEntity {
    public function doWork(): void {}
}

/** @template T */
interface Collection {
    /** @return T */
    public function get();
}

/**
 * @template T
 */
class Test
{
    /** @param T $foo */
    public function __construct($foo) {}

    /** @return Collection<T> */
    public function foobar(): Collection {}
}

$foo = new Test(new MyEntity());
$foo->foobar()->get()-><>